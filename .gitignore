# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Android signing & Play Store secrets (never commit)
*.keystore
google-play-key.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# IDE
.idea/
.vscode/*
!.vscode/extensions.json

# Claude Code kişisel ayarları (paylaşılan launch.json/settings.json commit edilebilir)
.claude/settings.local.json

# Geçici / üretilmiş veri ara dosyaları
*.log
